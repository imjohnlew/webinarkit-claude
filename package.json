{
  "name": "webinarkit-clone",
  "version": "1.0.0",
  "description": "WebinarKit-style backend for scheduled replay webinars",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
