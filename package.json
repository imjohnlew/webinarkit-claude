    "@supabase/supabase-js": "^2.39.0",
    "dotenv": "^16.3.1",
    "fastify": "^4.25.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.8",
    "date-fns": "^3.3.1",
    "date-fns-tz": "^3.1.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
