# ── Supabase Realtime (optional but recommended for production) ───────────────
# When set, WatchRoom uses WebSocket Broadcast + Presence instead of polling.
# This eliminates thundering-herd polling from 2 000 concurrent attendees.
#
# 1. Go to supabase.com → your project → Settings → API
# 2. Copy "Project URL"  → VITE_SUPABASE_URL
# 3. Copy "anon public"  → VITE_SUPABASE_ANON_KEY  (safe to expose in browser)
#
# Without these vars the app works fine with mock data and polling fallback.

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
